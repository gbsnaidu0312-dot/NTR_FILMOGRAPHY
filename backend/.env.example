# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Database Configuration (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=ntr_filmography
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Cloudflare R2 Storage Configuration
USE_CLOUDFLARE_R2=False

# Cloudflare R2 API Credentials (get from https://dash.cloudflare.com/ -> Account Settings -> API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key

# Cloudflare R2 Bucket Details
CLOUDFLARE_R2_BUCKET=ntr-filmography
CLOUDFLARE_R2_ENDPOINT=https://[account-id].r2.cloudflarestorage.com
CLOUDFLARE_R2_CUSTOM_DOMAIN=https://cdn.ntr-filmography.com
